# EA Portal — environment variables
# Copy to .env and fill in strong values before running in any non-demo context.

# =============================================================================
# Core secrets
# =============================================================================

# 32-byte key used for AES-256-GCM file encryption at rest.
# Provide either 32 ASCII chars or a 64-char hex string.
# Generate a hex key:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FILE_ENCRYPTION_KEY=change-this-to-a-32-byte-secret!!

# Session hashing — reserved for future use (tokens themselves are SHA-256 hashed in DB).
SESSION_SECRET=change-this-to-a-random-string

# First administrator account (created on first run only).
# The user will be forced to change the password on first login.
INITIAL_ADMIN_EMAIL=abdul@matloob-ea.com
INITIAL_ADMIN_PASSWORD=ChangeMe!2026

# Optional: port override (default 5000).
# PORT=5000

# =============================================================================
# Transactional email (Google Workspace SMTP)
# =============================================================================
# The portal sends notifications for signup, approval, file uploads, messages,
# and password resets. If these vars aren't set the portal still works — email
# sends are gracefully skipped and logged to audit_logs as `email_skipped_no_config`.
#
# --- How to get a Google Workspace app password (~2 min):
# 1. Sign in to https://admin.google.com as a super-admin and confirm 2-Step
#    Verification is enforced for the sending mailbox (contact@matloob-ea.com).
# 2. While signed in AS THAT MAILBOX, visit:
#      https://myaccount.google.com/apppasswords
# 3. Name the app "Matloob Portal" and click Create. Copy the 16-character
#    password (Google shows spaces — paste WITHOUT spaces into SMTP_PASSWORD).
# 4. Paste the 16-char string below. Never commit this file with a real value.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contact@matloob-ea.com
SMTP_PASSWORD=xxxxxxxxxxxxxxxx

# The "From" line on every outgoing email.
MAIL_FROM_NAME=Matloob Tax & Consulting
MAIL_FROM_EMAIL=contact@matloob-ea.com

# Where new-signup alerts and client-upload notifications are sent.
# Defaults to SMTP_USER if unset.
ADMIN_NOTIFY_EMAIL=contact@matloob-ea.com

# Public base URL of the deployed portal — used to build email links.
# Default shown is the current Perplexity deployment. Replace if you deploy
# the portal to your own domain (e.g. https://portal.matloob-ea.com).
PORTAL_BASE_URL=https://www.perplexity.ai/computer/a/matloob-ea-portal-BCBrVOunQ6GjG8Chky1vgA
